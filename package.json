{
  "name": "edumanage-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "EduManage - Multi-College Management System",
  "workspaces": [
    "frontend",
    "server",
    "shared"
  ],
  "scripts": {

     "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:server": "npm run dev --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
